# Hyper-V provider local development env vars.
# Copy to .env.local (gitignored) and fill in for `task test:acc`.
# See docs/PLAN.md §6 for the full list and precedence rules.

# ---------- Common ----------
# HYPERV_BACKEND=ssh         # one of: local | ssh | winrm
# HYPERV_HOST=hv01.example.com
# HYPERV_PORT=22
# HYPERV_USERNAME=Administrator
# HYPERV_PASSWORD=
# HYPERV_TIMEOUT=5m

# ---------- SSH ----------
# HYPERV_SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
# HYPERV_SSH_PASSPHRASE=
# HYPERV_SSH_KNOWN_HOSTS_PATH=~/.ssh/known_hosts

# ---------- WinRM ----------
# HYPERV_WINRM_USE_HTTPS=true
# HYPERV_WINRM_INSECURE=false
# HYPERV_WINRM_AUTH=ntlm    # one of: basic | ntlm | kerberos
# HYPERV_WINRM_CACERT=

# ---------- Local (provider runs ON the Hyper-V host) ----------
# HYPERV_PWSH_PATH=pwsh

# ---------- Acceptance tests (`task test:acc` only) ----------
# Workbench fixtures used by per-resource acc tests. See
# docs/contributing/acceptance-tests.md for setup.
#
# HYPERV_TEST_VHD_DIR        # Bench dir for ephemeral VHD/file creation
#                            # (e.g. C:\hyperv\tfacc). Must be writable
#                            # by HYPERV_USERNAME. The acc tests stamp
#                            # tfacc-* files under here and clean up via
#                            # CheckDestroy; manual sweep on test crash.
# HYPERV_TEST_HOST_FILE      # Pre-placed file path for the image_file
#                            # host_path-mode test (e.g. a small
#                            # C:\hyperv\tfacc-fixture.txt staged once).
#
# url-mode does not need fixture vars: the test stands up an
# httptest.Server on the runner's LAN IP and the bench downloads
# from there. Requires the bench to be able to route back to the
# runner (flat LAN works; NAT'd networks don't).
