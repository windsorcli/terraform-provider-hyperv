# Hyper-V provider local development env vars.
# Copy to .env.local (gitignored) and fill in for `task test:acc`.
# Provider attribute > env var > default is the precedence rule for
# every entry below.

# ---------- Common ----------
# HYPERV_BACKEND=ssh         # one of: local | ssh | winrm
# HYPERV_HOST=hv01.example.com
# HYPERV_PORT=22
# HYPERV_USERNAME=Administrator
# HYPERV_PASSWORD=
# HYPERV_TIMEOUT=5m

# ---------- SSH ----------
# HYPERV_SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
# HYPERV_SSH_PASSPHRASE=
# HYPERV_SSH_KNOWN_HOSTS_PATH=~/.ssh/known_hosts

# ---------- WinRM ----------
# HYPERV_WINRM_USE_HTTPS=true
# HYPERV_WINRM_INSECURE=false
# HYPERV_WINRM_AUTH=ntlm    # one of: ntlm (default) | basic | kerberos
# HYPERV_WINRM_CACERT=

# ---------- WinRM + Kerberos ----------
# Only meaningful when HYPERV_WINRM_AUTH=kerberos. Realm is required;
# the rest fall back to sane defaults. ccache mode is the validated
# path -- password mode against AD is currently blocked by an upstream
# masterzen/winrm bug (see docs/contributing/kerberos.md).
#
# HYPERV_KRB5_REALM=HV.LAB
# HYPERV_KRB5_SPN=                              # default: HTTP/<host>
# HYPERV_KRB5_CONF_PATH=                        # default: $KRB5_CONFIG, ~/.config/krb5.conf, /etc/krb5.conf (first existing)
# HYPERV_KRB5_CCACHE_PATH=/tmp/krb5cc_$(id -u)  # required for ccache mode; mutually exclusive with HYPERV_PASSWORD

# ---------- Local (provider runs ON the Hyper-V host) ----------
# HYPERV_PWSH_PATH=pwsh

# ---------- Acceptance tests (`task test:acc` only) ----------
# Workbench fixtures used by per-resource acc tests. See
# docs/contributing/acceptance-tests.md for setup.
#
# IMPORTANT: Windows paths in this file MUST be single-quoted -- bash
# strips backslashes from unquoted assignment values when sourced, so
# `HYPERV_TEST_VHD_DIR=C:\hyperv\tfacc` becomes `C:hypervtfacc` after
# `set -a; source .env.local`. Single-quotes preserve the backslashes
# verbatim. Forward slashes (`C:/hyperv/tfacc`) work too if you prefer.
#
# HYPERV_TEST_VHD_DIR='C:\hyperv\tfacc'    # Bench dir for ephemeral VHD/file
#                                          # creation. Must be writable by
#                                          # HYPERV_USERNAME. The acc tests
#                                          # stamp tfacc-* files under here
#                                          # and clean up via CheckDestroy;
#                                          # manual sweep on test crash.
# HYPERV_TEST_HOST_FILE='C:\hyperv\tfacc\fixture.txt'  # Pre-placed file for
#                                          # the image_file host_path-mode
#                                          # test (small text file staged
#                                          # once on the bench).
# HYPERV_TEST_ISO_FILE='C:\hyperv\tfacc\test.iso'      # Pre-placed ISO for
#                                          # the VM dvd_drive + boot_order
#                                          # tests. Any small ISO works (a
#                                          # few KB is fine).
#
# url-mode does not need fixture vars: the test stands up an
# httptest.Server on the runner's LAN IP and the bench downloads
# from there. Requires the bench to be able to route back to the
# runner (flat LAN works; NAT'd networks don't).

# ---------- Kerberos lab (`task lab:build-iso`) ----------
# Secrets baked into dist/autounattend.iso for the lab DC built by
# examples/lab/kerberos/. See examples/lab/kerberos/README.md.
#
# HVLAB_ADMIN_PASSWORD       # Local Administrator password set at
#                            # install time. Becomes the domain admin
#                            # password after AD DS promo. Avoid the
#                            # XML metacharacters <, >, & in the value.
# HVLAB_DSRM_PASSWORD        # Directory Services Restore Mode password.
#                            # Required by Install-ADDSForest. Stash in
#                            # a vault entry; rotate post-promo.
